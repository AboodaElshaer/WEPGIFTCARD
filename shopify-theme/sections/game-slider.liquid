<section class="py-16 relative">
  <div class="container max-w-7xl mx-auto px-4 md:px-8">
    <div class="flex justify-between items-end mb-10">
      <div>
        {%- if section.settings.subtitle != blank -%}
          <div class="flex items-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-secondary fill-secondary"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span class="text-sm font-bold uppercase tracking-widest text-secondary">{{ section.settings.subtitle }}</span>
          </div>
        {%- endif -%}
        <h2 class="text-3xl md:text-5xl font-display font-bold text-white">{{ section.settings.title }}</h2>
      </div>
    </div>

    <!-- Shopify doesn't have Embla built-in, so we use a CSS-only scroll snap container for products -->
    <div class="overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-8 pt-4">
      <div class="flex gap-6 min-w-max">
        {%- for block in section.blocks -%}
          <div class="snap-start w-[80vw] sm:w-[45vw] md:w-[30vw] lg:w-[22vw] min-w-0">
            <a href="{{ block.settings.product_url }}" class="group block relative rounded-2xl overflow-hidden glass-panel border border-white/10 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(0,255,255,0.2)] hover:border-primary/50 cursor-pointer">
              {%- if block.settings.is_hot -%}
                <div class="absolute top-4 left-4 z-20 bg-destructive text-destructive-foreground text-xs font-bold px-3 py-1 rounded-full flex items-center gap-1 shadow-[0_0_10px_rgba(255,0,0,0.5)]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                  HOT
                </div>
              {%- endif -%}
              
              <div class="aspect-[3/4] relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-t from-background via-background/20 to-transparent z-10"></div>
                {%- if block.settings.image != blank -%}
                  <img 
                    src="{{ block.settings.image | image_url: width: 600 }}" 
                    alt="{{ block.settings.title }}" 
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    loading="lazy"
                  />
                {%- else -%}
                  <div class="w-full h-full bg-muted flex items-center justify-center text-muted-foreground">No image</div>
                {%- endif -%}
                
                <div class="absolute bottom-0 left-0 right-0 p-5 z-20 translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                  <div class="text-xs text-primary font-bold tracking-wider mb-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100">{{ block.settings.category }}</div>
                  <h3 class="text-xl font-bold text-white font-display mb-2">{{ block.settings.title }}</h3>
                  <div class="flex items-center justify-between">
                    <span class="font-bold text-white/90">{{ block.settings.price }}</span>
                    <span class="inline-flex items-center justify-center text-sm font-medium rounded-full bg-primary/20 text-primary border border-primary/50 group-hover:bg-primary group-hover:text-background h-8 px-4 opacity-0 group-hover:opacity-100 transition-all duration-300 delay-150">
                      TOP UP
                    </span>
                  </div>
                </div>
              </div>
            </a>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

{% schema %}
{
  "name": "Game Slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "TRENDING NOW"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "HOT DROPS"
    }
  ],
  "blocks": [
    {
      "type": "game",
      "name": "Game Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Game Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Game Title"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "BATTLE ROYALE"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price Display",
          "default": "From $4.99"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product Link"
        },
        {
          "type": "checkbox",
          "id": "is_hot",
          "label": "Show HOT Badge",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Game Slider",
      "blocks": [
        { "type": "game", "settings": { "title": "Game 1" } },
        { "type": "game", "settings": { "title": "Game 2" } },
        { "type": "game", "settings": { "title": "Game 3" } }
      ]
    }
  ]
}
{% endschema %}