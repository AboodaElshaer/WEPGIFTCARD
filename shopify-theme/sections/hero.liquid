<section class="relative min-h-[90vh] flex items-center pt-24 overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="{{ 'hero-bg.png' | asset_url }}" 
      alt="Hero Background" 
      class="w-full h-full object-cover opacity-40 mix-blend-screen scale-105 animate-pulse-slow"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-background/20 via-background/60 to-background"></div>
    <div class="absolute inset-0 bg-grid-pattern opacity-30"></div>
  </div>

  <div class="container max-w-7xl mx-auto px-4 md:px-8 relative z-10">
    <div class="max-w-3xl">
      <div class="animate-in fade-in slide-in-from-bottom-8 duration-700">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full glass-panel border-primary/30 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-primary"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <span class="text-xs font-bold uppercase tracking-widest text-primary">{{ section.settings.badge_text }}</span>
        </div>
      </div>

      <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-black text-white leading-[1.1] tracking-tight mb-6 animate-in fade-in slide-in-from-bottom-8 duration-700 delay-100">
        {{ section.settings.title | replace: 'GAMING', '<span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-accent neon-text">GAMING</span>' }}
      </h1>

      <p class="text-lg md:text-xl text-muted-foreground mb-10 max-w-2xl font-light animate-in fade-in slide-in-from-bottom-8 duration-700 delay-200">
        {{ section.settings.description }}
      </p>

      <div class="flex flex-wrap items-center gap-4 animate-in fade-in slide-in-from-bottom-8 duration-700 delay-300">
        {%- if section.settings.button_1_link != blank -%}
          <div class="glow-btn rounded-full">
            <a href="{{ section.settings.button_1_link }}" class="inline-flex items-center justify-center whitespace-nowrap bg-background text-white hover:bg-background/90 border border-primary/50 rounded-full h-14 px-8 text-lg font-bold font-display tracking-widest group relative overflow-hidden z-10">
              <div class="absolute inset-0 bg-gradient-to-r from-primary/20 to-secondary/20 group-hover:opacity-100 opacity-0 transition-opacity"></div>
              {{ section.settings.button_1_text }}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
        {%- endif -%}
        
        {%- if section.settings.button_2_link != blank -%}
          <a href="{{ section.settings.button_2_link }}" class="inline-flex items-center justify-center whitespace-nowrap rounded-full h-14 px-8 text-lg font-bold font-display tracking-widest text-white hover:bg-white/10 transition-colors">
            {{ section.settings.button_2_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
  
  <!-- Decorative floating elements -->
  <div class="absolute right-[10%] top-[30%] w-64 h-64 bg-primary/20 rounded-full blur-[100px] animate-pulse"></div>
  <div class="absolute right-[25%] bottom-[20%] w-72 h-72 bg-secondary/20 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Instant Delivery"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "LEVEL UP YOUR <br /> GAMING ARSENAL"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Premium digital top-ups, game keys, and direct recharges for the world's most popular titles. Delivered instantly to your account."
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Primary Button Text",
      "default": "EXPLORE GAMES"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Primary Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Secondary Button Text",
      "default": "VIEW OFFERS"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}